# ===========================================
# LiveKit Outbound Calling Agent - Environment
# ===========================================

# -------------------------------------------
# LiveKit + VoBiz (Required)
# -------------------------------------------
# Get these from https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
OUTBOUND_TRUNK_ID=ST_xxxxx
VOBIZ_SIP_DOMAIN=your-sip-domain.sip.vobiz.ai
VOBIZ_AUTH_ID=your_auth_id
VOBIZ_AUTH_TOKEN=your_auth_token
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_CALLER_ID=+91xxxxxxxxxx
VOBIZ_OUTBOUND_NUMBER=+91xxxxxxxxxx
VOBIZ_INBOUND_NUMBER=+91xxxxxxxxxx
VOBIZ_TRUNK_NAME=vobiz-outbound-auto
DEFAULT_TRANSFER_NUMBER=+91xxxxxxxxxx

# -------------------------------------------
# OpenAI API (Required)
# -------------------------------------------
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
REALTIME_PROVIDER=openai
OPENAI_REALTIME_VOICE=alloy
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# -------------------------------------------
# Voice Provider Keys (Optional)
# -------------------------------------------
TTS_PROVIDER=openai
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
CARTESIA_API_KEY=
ASSEMBLYAI_API_KEY=
CARTESIA_TTS_MODEL=sonic-2
CARTESIA_TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02

# -------------------------------------------
# Google API (Optional, post-call analysis)
# -------------------------------------------
GOOGLE_API_KEY=
GOOGLE_REALTIME_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GOOGLE_REALTIME_VOICE=Kore
VOICE_STYLE_HINT=Speak in a bright, slightly higher-pitched feminine tone while staying natural and clear on phone audio.

# -------------------------------------------
# MongoDB + Redis (Required)
# -------------------------------------------
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/vobiz_calls
MONGODB_DB_NAME=vobiz_calls
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# -------------------------------------------
# API Server Configuration
# -------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=https://your-frontend.vercel.app
ANALYTICS_SERVICE_URL=http://analytics:8001
ORCHESTRATION_SERVICE_URL=http://orchestration:8003
CONFIG_SERVICE_URL=http://config:8002

# -------------------------------------------
# Authentication
# -------------------------------------------
# Set to false to disable auth (all APIs public)
AUTH_ENABLED=true

# JWT secret key (generate a strong random key for production)
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_API_KEY=change_this_internal_api_key

# -------------------------------------------
# AWS S3 (Optional, recordings)
# -------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1
