# Voice AI Platform environment template
# Copy this file to .env (used by root scripts and root docker-compose).
# If you use backend/docker-compose.yml directly, copy the same values to backend/.env.local.

# ===========================
# LiveKit + VoBiz (Required)
# ===========================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxx
VOBIZ_SIP_DOMAIN=your-sip-domain.sip.vobiz.ai
LIVEKIT_SIP_URI=sip:your-project-id.sip.livekit.cloud
VOBIZ_AUTH_ID=your_vobiz_auth_id
VOBIZ_AUTH_TOKEN=your_vobiz_auth_token
VOBIZ_CALLER_ID=+91XXXXXXXXXX
VOBIZ_USERNAME=your_vobiz_username
VOBIZ_PASSWORD=your_vobiz_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
VOBIZ_INBOUND_NUMBER=+91XXXXXXXXXX
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
DEFAULT_OUTBOUND_TARGET=+91XXXXXXXXXX
AGENT_PERSONA_NAME=Shubhi
AGENT_COMPANY_NAME=Estate Company
AGENT_DEFAULT_LANGUAGE=hi
VOBIZ_TRUNK_NAME=Demo
OUTBOUND_FIRST_MESSAGE=Namaste, main Shubhi Estate Company se bol rahi hoon. Kya abhi baat karna theek rahega?
NO_SPEECH_REPROMPT_SEC=4

# ===========================
# OpenAI (Required)
# ===========================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_REALTIME_AUDIO=true
REALTIME_PROVIDER=openai
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_SPEED=1.00
OPENAI_REALTIME_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_TRANSCRIBE_LANGUAGE=hi
OPENAI_REALTIME_INPUT_NOISE_REDUCTION=near_field
OPENAI_REALTIME_TURN_THRESHOLD=0.40
OPENAI_REALTIME_PREFIX_PADDING_MS=220
OPENAI_REALTIME_SILENCE_DURATION_MS=180
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=marin
OPENAI_TTS_SPEED=1.00
OPENAI_TTS_RESPONSE_FORMAT=pcm
OPENAI_TTS_INSTRUCTIONS=Speak in a clean, smooth, natural feminine voice. Keep the tone calm and clear for phone audio.
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_LANGUAGE=hi
OPENAI_STT_USE_REALTIME=true
OPENAI_STT_TURN_THRESHOLD=0.45
OPENAI_STT_PREFIX_PADDING_MS=250
OPENAI_STT_SILENCE_DURATION_MS=220

# ===========================
# Voice Provider Options
# ===========================
TTS_PROVIDER=openai
STT_PROVIDER=openai
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
CARTESIA_API_KEY=
ASSEMBLYAI_API_KEY=
CARTESIA_TTS_MODEL=sonic-2
CARTESIA_TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02
ENABLE_NOISE_CANCELLATION=true
ROOM_AUDIO_FRAME_SIZE_MS=20
VAD_MIN_SPEECH_DURATION=0.04
VAD_MIN_SILENCE_DURATION=0.25
VAD_PREFIX_PADDING_DURATION=0.25
VAD_ACTIVATION_THRESHOLD=0.35
SESSION_MIN_INTERRUPTION_DURATION=0.10
SESSION_MIN_ENDPOINTING_DELAY=0.14
SESSION_MAX_ENDPOINTING_DELAY=0.45
SESSION_FALSE_INTERRUPTION_TIMEOUT=0.35
SESSION_PREEMPTIVE_GENERATION=true
AGENT_NUM_IDLE_PROCESSES=3
TRANSFER_REQUIRE_CONFIRMATION=true
TRANSFER_CONFIRM_TIMEOUT_SEC=30

# ===========================
# Analytics / AI (Optional)
# ===========================
GOOGLE_API_KEY=
GOOGLE_REALTIME_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GOOGLE_REALTIME_VOICE=Kore
VOICE_STYLE_HINT=Speak in a bright, slightly higher-pitched feminine tone while staying natural and clear on phone audio.

# ===========================
# Database + Cache (Required)
# ===========================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vobiz_calls
MONGODB_DB_NAME=vobiz_calls
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# ===========================
# API
# ===========================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=https://your-frontend.vercel.app
ANALYTICS_SERVICE_URL=http://analytics:8001
ORCHESTRATION_SERVICE_URL=http://orchestration:8003
CONFIG_SERVICE_URL=http://config:8002

# ===========================
# Authentication
# ===========================
AUTH_ENABLED=true
JWT_SECRET_KEY=change_this_to_a_long_random_value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_API_KEY=change_this_internal_api_key

# ===========================
# AWS S3 Recordings (Optional)
# ===========================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1
