# Use lightweight Python image
FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Environment settings
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv (fast pip alternative)
RUN pip install --no-cache-dir uv

# Copy requirements first (for caching)
COPY backend/requirements.txt ./requirements.txt

# Install Python dependencies
RUN uv pip install --system -r requirements.txt

# Copy backend code
COPY backend/shared ./shared
COPY backend/services ./services

# Create logs directory
RUN mkdir -p /app/logs

# Railway healthcheck (dynamic PORT)
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD sh -c "curl -f http://127.0.0.1:${PORT:-8000}/health || exit 1"

# 🚀 START SERVER (IMPORTANT FIX)
CMD ["sh", "-c", "uvicorn services.gateway.main:app --host 0.0.0.0 --port ${PORT:-8000} --proxy-headers --forwarded-allow-ips '*'"]