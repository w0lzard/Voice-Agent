# Frontend Environment Configuration
# Copy this file to .env.local

# ─── Vercel Environment Variables ───────────────────────────────────────────
#
# GATEWAY_URL (server-side only, NOT prefixed with NEXT_PUBLIC_)
# This is used by the Next.js API proxy route to reach the Railway backend.
# Set this in Vercel project settings → Environment Variables.
GATEWAY_URL=https://zoological-reflection-production.up.railway.app

# ─── IMPORTANT: Do NOT set NEXT_PUBLIC_API_BASE to the Railway URL! ─────────
#
# NEXT_PUBLIC_API_BASE controls where the BROWSER sends API requests.
# If set to the Railway URL, the browser makes direct cross-origin requests,
# causing CORS preflight failures (OPTIONS → 400).
#
# Leave it empty (or omit entirely) so the browser uses the relative path
# /api, which goes through the Next.js proxy — no CORS needed.
#
# NEXT_PUBLIC_API_BASE=
# NEXT_PUBLIC_API_URL=

# ─── Other public variables ─────────────────────────────────────────────────
# NEXT_PUBLIC_WS_SERVER=wss://your-ws-server
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
